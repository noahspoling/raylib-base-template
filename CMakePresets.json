{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "linux-desktop",
      "inherits": "template-base",
      "displayName": "Desktop (Linux)",
      "cacheVariables": {
        "GRAMARYE_TARGET": "desktop"
      }
    },
    {
      "name": "macos-desktop",
      "inherits": "template-base",
      "displayName": "Desktop (macOS)",
      "cacheVariables": {
        "GRAMARYE_TARGET": "desktop"
      }
    },
    {
      "name": "web-wasm",
      "inherits": "template-base",
      "displayName": "Web (Emscripten)",
      "cacheVariables": {
        "GRAMARYE_TARGET": "web"
      },
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
    },
    {
      "name": "android-ndk",
      "inherits": "template-base",
      "displayName": "Android (NDK)",
      "cacheVariables": {
        "GRAMARYE_TARGET": "android",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-24"
      },
      "toolchainFile": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake"
    },
    {
      "name": "macos-gles-angle",
      "inherits": "template-base",
      "displayName": "macOS OpenGL ES 2 + ANGLE (link ANGLE yourself)",
      "cacheVariables": {
        "GRAMARYE_TARGET": "macos_gles_angle"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-desktop",
      "configurePreset": "linux-desktop"
    },
    {
      "name": "macos-desktop",
      "configurePreset": "macos-desktop"
    },
    {
      "name": "web-wasm",
      "configurePreset": "web-wasm"
    },
    {
      "name": "android-ndk",
      "configurePreset": "android-ndk"
    },
    {
      "name": "macos-gles-angle",
      "configurePreset": "macos-gles-angle"
    }
  ]
}
